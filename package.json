{
  "name": "confidential-indexer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev:db": "docker compose -f compose.dev.yaml up -d postgres",
    "docker:dev": "docker compose -f compose.dev.yaml up --build",
    "docker:prod": "docker compose up --build",
    "live:accounts": "tsx packages/zama/scripts/create-live-accounts.ts",
    "live:deploy": "forge build && node --env-file=${LIVE_ENV_FILE:-.env.live} --import tsx packages/zama/scripts/deploy-contract.ts --update-env",
    "live:scan": "node --env-file=${LIVE_ENV_FILE:-.env.live} --import tsx apps/hyperindex/src/scan-once.ts",
    "live:transfer": "node --env-file=${LIVE_ENV_FILE:-.env.live} --import tsx packages/zama/scripts/transfer-and-delegate.ts",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.5.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.10.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^0.15.12",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.4"
}
